<Window x:Class="Tema8.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tema 8 - Interior Poligon" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Background="#FFE0E0E0" LastChildFill="False">
            <StackPanel Orientation="Horizontal" Margin="5,2">
                <Button x:Name="ResetButton" Content="Resetare" Margin="0,0,5,0" Padding="10,4"/>
                <TextBlock VerticalAlignment="Center" Margin="10,0" Foreground="#333" FontWeight="SemiBold">
                    1. Click Stânga: Adaugă Vârfuri | 2. Click Dreapta: Închide Poligonul | 3. Drag: Mută Poligonul
                </TextBlock>
            </StackPanel>
        </DockPanel>

        <Canvas x:Name="DrawingCanvas"
                Grid.Row="1"
                Background="White" 
                ClipToBounds="True"/>
    </Grid>
</Window>