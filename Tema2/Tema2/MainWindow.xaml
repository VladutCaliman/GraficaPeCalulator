<Window x:Class="Tema2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tema2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
               Background="#FFE0E0E0"
               Panel.ZIndex="1"
               LastChildFill="False">
            <StackPanel Orientation="Horizontal" Margin="5,2">
                <Button x:Name="ElipsisButton"
                    Content="Draw Elipsis"
                    Margin="0,0,5,0"
                    Padding="10,4"
                    Click="ElipsisButton_Click"/>

                <Button x:Name="SpiralButton"
                    Content="Draw Spiral"
                    Margin="0,0,5,0"
                    Padding="10,4"
                    Click="SpiralButton_Click"/>

                <Button x:Name="ParabolaButton"
                    Content="Draw Parabola"
                    Margin="0,0,5,0"
                    Padding="10,4"
                    Click="ParabolaButton_Click"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Canvas x:Name="DrawingCanvas"
                Background="White" />
        </Grid>
    </Grid>
</Window>
